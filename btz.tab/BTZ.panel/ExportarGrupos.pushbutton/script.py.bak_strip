    u"Duct Fittings": u"instalaciones",
    u"Mechanical Equipment": u"instalaciones",
    u"Electrical Equipment": u"instalaciones",
    u"Electrical Fixtures": u"instalaciones",
    u"Plumbing Fixtures": u"instalaciones",
}

