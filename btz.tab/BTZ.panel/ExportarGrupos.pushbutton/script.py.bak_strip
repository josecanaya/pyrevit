    u"BTZ_Description_12",
    u"BTZ_Description_13",
]
ALL_BTZ_PARAMS = [PARAM_BASE] + PARAM_NUMERIC

# Metadatos sugerencia IA (mismo TXT que BTZ_Description; vincular con ensure_btz_shared_parameters)
PARAM_STATUS = u"BTZ_Status"
